!src/joy_mux
!src/ovis_ros2
!src/input_manager
!src/capra_twist_mux
!src/capra_stamp_demux

# Ignore Python bytecodes
__pycache__/
*.pyc

# Ignore temp files
*.tmp
*.temp

# Ignore files related to your dev environment
.vscode/

# generated map database by rtabmap
*.db

# flipper positions
flipper_pos.json