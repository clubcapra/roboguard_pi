# Ignore build and log directories
build/
log/
install/

# Ignore everything in src except local and submodule packages
src/*
!src/roboguard_*
!src/better_odrive
!src/capra_control_msgs
!src/capra_flippers_teleop
!src/capra_joy_to_bool
